{
  "name": "design-system-workspace",
  "version": "0.1.0",
  "lockfileVersion": 3,
  "requires": true,
  "packages": {
    "": {
      "name": "design-system-workspace",
      "version": "0.1.0",
      "workspaces": [
        "apps/*",
        "packages/*"
      ],
      "engines": {
        "node": ">=18"
      }
    },
    "node_modules/@workspace/tokens": {
      "resolved": "packages/tokens",
      "link": true
    },
    "node_modules/@workspace/ui": {
      "resolved": "packages/ui",
      "link": true
    },
    "packages/tokens": {
      "name": "@workspace/tokens",
      "version": "0.1.0"
    },
    "packages/ui": {
      "name": "@workspace/ui",
      "version": "0.1.0"
    }
  }
}
